---
import Base from '../layouts/Base.astro';
import type { Cocktail, CocktailOriginStories } from '../types';
import { buildPrettyFilterHref } from '../utils/filter-url';
import { getGlassServingText } from '../utils/glass';
import { buildRecipeSchema, formatIngredientAmount } from '../utils/schema';
import cocktails from '../../cocktails.json';
import originStories from '../../origin-stories.json';

export function getStaticPaths() {
  return (cocktails as Cocktail[]).map(cocktail => ({
    params: { slug: cocktail.slug },
    props: { cocktail },
  }));
}

interface Props {
  cocktail: Cocktail;
}

const { cocktail } = Astro.props;

import { existsSync, statSync } from 'node:fs';
import { join } from 'node:path';
const imageFilePath = join(process.cwd(), 'public/images', `${cocktail.slug}.webp`);
const hasImage = existsSync(imageFilePath) && statSync(imageFilePath).size > 0;
const image320Src = hasImage ? `/images/responsive/320/${cocktail.slug}.webp` : null;
const image640Src = hasImage ? `/images/responsive/640/${cocktail.slug}.webp` : null;
const siteUrl = Astro.site?.toString() ?? 'https://cocktail.glass';
const schemaImageUrl = hasImage ? new URL(`/images/${cocktail.slug}.webp`, siteUrl).toString() : undefined;
const originStory = (originStories as CocktailOriginStories)[cocktail.slug];

const brandHints: Record<string, string> = {
  'Coffee liqueur': 'e.g. Kahlúa, Mr. Black',
  'Elderflower liqueur': 'e.g. St-Germain',
  'Maraschino liqueur': 'e.g. Luxardo',
  'Chocolate liqueur': 'e.g. Crème de Cacao, Mozart',
  'Banana liqueur': 'e.g. Giffard Banane du Brésil',
  'Sour apple liqueur': 'e.g. Sour Puss, DeKuyper',
  'Gentiane liqueur': 'e.g. Suze, Salers',
  'Peach liqueur': 'e.g. Crème de Pêche, Giffard',
  'Pear liqueur': 'e.g. Belle de Brillet, St. George',
  'Passion fruit liqueur': 'e.g. Passoã',
  'Blackberry liqueur': 'e.g. Crème de Mûre, Chambord',
  'Dry vermouth': 'e.g. Noilly Prat, Dolin Dry',
  'Sweet vermouth': 'e.g. Carpano Antica, Cocchi di Torino',
  'Blanc vermouth': 'e.g. Dolin Blanc, Lillet Blanc',
  'Bourbon': 'e.g. Maker\'s Mark, Buffalo Trace, Woodford Reserve',
  'Rye whiskey': 'e.g. Rittenhouse, Bulleit Rye, Old Overholt',
  'Scotch': 'e.g. Johnnie Walker, Monkey Shoulder',
  'Blended Scotch': 'e.g. Johnnie Walker, Famous Grouse',
  'Islay Scotch': 'e.g. Laphroaig, Ardbeg, Lagavulin',
  'Irish whiskey': 'e.g. Jameson, Redbreast',
  'Japanese whisky': 'e.g. Nikka, Suntory Toki',
};
const pageUrl = new URL(Astro.url.pathname, siteUrl).toString();
const recipeSchema = buildRecipeSchema(siteUrl, pageUrl, cocktail, schemaImageUrl);
const categoryHref = buildPrettyFilterHref('category', cocktail.category);
const glassHref = buildPrettyFilterHref('glass', cocktail.glass);
---
<Base
  title={cocktail.name}
  description={`How to make a ${cocktail.name}: ${cocktail.preparation}`}
  ogImage={`/og/${cocktail.slug}.jpg`}
  schema={recipeSchema}
>
  <div class="container">
    <a href="/" class="back">&larr; All cocktails</a>

    <article class="cocktail-card">
      <header>
        <div class="header-copy">
          <a href={categoryHref} class="category category-link">
            {cocktail.category}
          </a>
          <h1>{cocktail.name}</h1>
          <p class="glass-type">
            Served in <a href={glassHref} class="glass-link">{getGlassServingText(cocktail.glass)}</a>
          </p>
          <div class="browse-links" aria-label="Browse related cocktails">
            <a href={categoryHref} class="meta-link">More {cocktail.category}</a>
            <a href={glassHref} class="meta-link">More in {cocktail.glass}</a>
          </div>
        </div>
        {image320Src && image640Src && (
          <img
            src={image320Src}
            srcset={`${image320Src} 320w, ${image640Src} 640w`}
            sizes="(max-width: 600px) calc(100vw - 5rem), 320px"
            alt={cocktail.name}
            class="cocktail-image"
            width="320"
            height="320"
            loading="eager"
            fetchpriority="high"
          />
        )}
      </header>

      <div class="content">
        <section class="ingredients">
          <h2>Ingredients</h2>
          <ul>
            {cocktail.ingredients.map(ing => (
              <li>
                <span class="amount">{formatIngredientAmount(ing)}</span>
                <span class="ingredient-name">
                  <a href={buildPrettyFilterHref('ingredient', ing.name)} class="ingredient-link">{ing.name}</a>
                  {brandHints[ing.name] && <span class="brand-hint">{brandHints[ing.name]}</span>}
                </span>
              </li>
            ))}
          </ul>
        </section>

        <section class="preparation" id="recipe-step-1">
          <h2>Preparation</h2>
          <p>{cocktail.preparation}</p>
        </section>

        {cocktail.garnish && (
          <section class="garnish" id="recipe-step-2">
            <h2>Garnish</h2>
            <p>{cocktail.garnish}</p>
          </section>
        )}

        {originStory?.story && (
          <section class="origin-story">
            <h2>Origin Story</h2>
            <p>{originStory.story}</p>
            {originStory.sourceUrl && (
              <p class="origin-source">
                Source:{' '}
                <a href={originStory.sourceUrl} target="_blank" rel="noreferrer">
                  {originStory.sourceName || 'Reference'}
                </a>
              </p>
            )}
          </section>
        )}
      </div>
    </article>
  </div>
</Base>

<style>
  .container {
    max-width: 860px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .back {
    display: inline-block;
    margin: 2rem 0 1.5rem;
    font-size: 1.1rem;
    color: var(--color-text-muted);
    font-weight: 500;
    transition: color 0.15s;
  }

  .back:hover {
    color: var(--color-accent);
  }

  .cocktail-card {
    background: var(--glass-bg);
    backdrop-filter: blur(var(--glass-blur));
    -webkit-backdrop-filter: blur(var(--glass-blur));
    border: 1px solid var(--glass-border);
    border-radius: 24px;
    padding: 2.5rem;
    box-shadow: var(--glass-shadow);
  }

  header {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding-bottom: 2rem;
    margin-bottom: 2rem;
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
  }

  .cocktail-image {
    display: block;
    width: 100%;
    max-width: 320px;
    height: auto;
    border-radius: 20px;
    margin-bottom: 1.5rem;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.1);
  }

  .category {
    display: inline-flex;
    align-items: center;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    font-weight: 600;
    background: rgba(224, 94, 58, 0.1);
    padding: 0.3rem 0.75rem;
    border-radius: 100px;
    margin-bottom: 0.75rem;
  }

  .category-link:hover {
    color: var(--color-accent-hover);
    background: rgba(224, 94, 58, 0.16);
  }

  h1 {
    font-family: var(--font-display);
    font-size: 3rem;
    font-weight: 600;
    margin: 0.5rem 0 0.25rem;
    line-height: 1.2;
    letter-spacing: -0.01em;
  }

  .glass-type {
    color: var(--color-text-muted);
    font-size: 1.2rem;
  }

  .glass-link {
    color: inherit;
    text-decoration: underline;
    text-decoration-color: rgba(224, 94, 58, 0.28);
    text-underline-offset: 0.18em;
  }

  .glass-link:hover {
    color: var(--color-accent);
  }

  .header-copy {
    max-width: 420px;
  }

  .browse-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    margin-top: 1rem;
  }

  .meta-link {
    display: inline-flex;
    align-items: center;
    min-height: 2.4rem;
    padding: 0.45rem 0.85rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.55);
    border: 1px solid rgba(0, 0, 0, 0.05);
    color: var(--color-text);
    font-size: 0.95rem;
    font-weight: 500;
    transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease;
  }

  .meta-link:hover {
    background: rgba(255, 255, 255, 0.78);
    color: var(--color-accent);
    border-color: rgba(224, 94, 58, 0.16);
  }

  .content h2 {
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
    font-weight: 600;
  }

  .ingredients {
    margin-bottom: 2rem;
  }

  .ingredients ul {
    list-style: none;
  }

  .ingredients li {
    display: flex;
    gap: 1rem;
    padding: 0.6rem 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.05);
  }

  .ingredients li:last-child {
    border-bottom: none;
  }

  .amount {
    min-width: 80px;
    color: var(--color-accent);
    font-weight: 600;
    font-size: 1.1rem;
  }

  .ingredient-name {
    font-size: 1.15rem;
  }

  .ingredient-link {
    color: var(--color-text);
    text-decoration: underline;
    text-decoration-color: rgba(224, 94, 58, 0.24);
    text-underline-offset: 0.16em;
  }

  .ingredient-link:hover {
    color: var(--color-accent);
  }

  .brand-hint {
    display: inline;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-left: 0.4rem;
  }

  .preparation {
    margin-bottom: 2rem;
  }

  .preparation p {
    line-height: 1.8;
  }

  .origin-story {
    margin-bottom: 2rem;
  }

  .origin-story p {
    line-height: 1.8;
  }

  .origin-source {
    margin-top: 0.85rem;
    font-size: 0.95rem;
    color: var(--color-text-muted);
  }

  .origin-source a {
    color: var(--color-accent);
  }

  .garnish {
    margin-bottom: 2rem;
  }

  .garnish p {
    color: var(--color-text-muted);
    font-style: italic;
  }

  @media (max-width: 600px) {
    .cocktail-card {
      padding: 1.5rem;
      border-radius: 20px;
    }

    .cocktail-image {
      margin-top: 0.5rem;
    }

    h1 {
      font-size: 2.5rem;
    }

    .browse-links {
      gap: 0.5rem;
    }
  }

  @media (min-width: 760px) {
    header {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: 2.5rem;
    }

    .cocktail-image {
      flex: 0 0 320px;
      margin-bottom: 0;
    }
  }
</style>
