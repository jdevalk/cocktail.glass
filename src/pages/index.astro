---
import Base from '../layouts/Base.astro';
import type { Cocktail } from '../types';
import { toFilterSlug } from '../utils/filter-url';
import { buildHomepageSchema } from '../utils/schema';
import cocktails from '../../cocktails.json';

const siteUrl = Astro.site?.toString() ?? 'https://cocktail.glass';
const homepageSchema = buildHomepageSchema(siteUrl, cocktails as Cocktail[]);

const allCocktails = (cocktails as Cocktail[]).map((c) => ({
  name: c.name,
  slug: c.slug,
  category: c.category,
  glass: c.glass,
  ingredients: c.ingredients.map((i) => i.name),
}));

// Build grouped categories in order
const categoryOrder: string[] = [];
const grouped = new Map<string, typeof allCocktails>();
for (const c of allCocktails) {
  if (!grouped.has(c.category)) {
    categoryOrder.push(c.category);
    grouped.set(c.category, []);
  }
  grouped.get(c.category)!.push(c);
}

// Count values for filter pills
function countBy(values: string[]) {
  const m = new Map<string, number>();
  for (const v of values) m.set(v, (m.get(v) || 0) + 1);
  return [...m.entries()].sort((a, b) => b[1] - a[1]);
}

// First 4 cocktails in display order should be eager-loaded (above the fold)
const eagerSlugs = new Set(
  categoryOrder.flatMap((cat) => grouped.get(cat)!.map((c) => c.slug)).slice(0, 4)
);

const categoryCounts = countBy(allCocktails.map((c) => c.category));
const glassCounts = countBy(allCocktails.map((c) => c.glass));
const ingredientCounts = countBy(allCocktails.flatMap((c) => [...new Set(c.ingredients)]));
---
<Base
  title="Cocktail Glass — 500 recipes by category, glass, and ingredient"
  description="Browse 500 cocktail recipes with ingredients, glassware, and preparation methods."
  ogImage="/og/home.jpg"
  graph={homepageSchema}
  preloadImage={`/images/responsive/320/${categoryOrder.flatMap(cat => grouped.get(cat)!)[0].slug}.webp`}
>
  <span slot="headerMeta" class="header-summary">500 cocktails to browse</span>
  <div slot="headerActions" class="header-actions-group">
    <a href="#cocktail-grid" class="header-action">Browse filters</a>
  </div>
  <div class="container" data-pagefind-ignore>
    <section class="hero">
      <img src="/emoji/cocktail-glass.svg" alt="" class="hero-icon" width="64" height="64" aria-hidden="true" />
      <h1>cocktail<span>.glass</span></h1>
      <p class="subtitle">Browse 500 cocktail recipes by<br />category, glass, and ingredient</p>
    </section>

    <div id="cocktail-grid">
      <div class="filters">
        <div class="filter-tabs" role="tablist" aria-label="Browse filters">
          <div class="filter-tabs-left">
            <button
              type="button"
              class="filter-tab filter-tab--active"
              data-tab="category"
              id="tab-category"
              role="tab"
              aria-selected="true"
              aria-controls="panel-category"
            >
              Category
            </button>
            <button
              type="button"
              class="filter-tab"
              data-tab="glass"
              id="tab-glass"
              role="tab"
              aria-selected="false"
              aria-controls="panel-glass"
              tabindex="-1"
            >
              Glass Type
            </button>
            <button
              type="button"
              class="filter-tab"
              data-tab="ingredients"
              id="tab-ingredients"
              role="tab"
              aria-selected="false"
              aria-controls="panel-ingredients"
              tabindex="-1"
            >
              Ingredients
            </button>
            <button
              type="button"
              class="filter-tab"
              data-tab="name"
              id="tab-name"
              role="tab"
              aria-selected="false"
              aria-controls="panel-name"
              tabindex="-1"
            >
              Search
            </button>
          </div>
        </div>

        <div class="filter-panel" id="filter-panel">
          <div class="pill-group" data-panel="category" id="panel-category" role="tabpanel" aria-labelledby="tab-category">
            {categoryCounts.map(([cat, count]) => (
              <div class="pill pill--category" data-filter="category" data-value={cat} data-slug={toFilterSlug(cat)} data-state="none">
                <button type="button" class="pill-action pill-action--include" data-action="include">
                  <span aria-hidden="true">+</span>
                  <span class="sr-only">Include {cat}</span>
                </button>
                <span class="pill-label">
                  {cat}
                </span>
              </div>
            ))}
          </div>
          <div class="pill-group" data-panel="glass" id="panel-glass" role="tabpanel" aria-labelledby="tab-glass" hidden>
            {glassCounts.map(([glass, count]) => (
              <div class="pill" data-filter="glass" data-value={glass} data-slug={toFilterSlug(glass)} data-state="none">
                <button type="button" class="pill-action pill-action--include" data-action="include">
                  <span aria-hidden="true">+</span>
                  <span class="sr-only">Include {glass}</span>
                </button>
                <span class="pill-label">
                  {glass}
                </span>
                <button type="button" class="pill-action pill-action--exclude" data-action="exclude">
                  <span aria-hidden="true">&minus;</span>
                  <span class="sr-only">Exclude {glass}</span>
                </button>
              </div>
            ))}
          </div>
          <div data-panel="ingredients" id="panel-ingredients" role="tabpanel" aria-labelledby="tab-ingredients" hidden>
            <label class="sr-only" for="ingredient-search">Search ingredients</label>
            <input
              type="text"
              class="ingredient-search"
              placeholder="Search ingredients…"
              id="ingredient-search"
              name="ingredient-search"
              autocomplete="off"
              spellcheck="false"
            />
            <div class="pill-group" id="ingredient-pills">
              {ingredientCounts.map(([ing, count], i) => (
                <div
                  class="pill"
                  data-filter="ingredient"
                  data-value={ing}
                  data-slug={toFilterSlug(ing)}
                  data-state="none"
                  hidden={i >= 20}
                >
                  <button type="button" class="pill-action pill-action--include" data-action="include">
                    <span aria-hidden="true">+</span>
                    <span class="sr-only">Include {ing}</span>
                  </button>
                  <span class="pill-label">
                    {ing}
                  </span>
                  <button type="button" class="pill-action pill-action--exclude" data-action="exclude">
                    <span aria-hidden="true">&minus;</span>
                    <span class="sr-only">Exclude {ing}</span>
                  </button>
                </div>
              ))}
            </div>
            <button type="button" class="show-more" id="show-more-ingredients" aria-controls="ingredient-pills" aria-expanded="false">
              Show all {ingredientCounts.length} ingredients
            </button>
          </div>
          <div data-panel="name" id="panel-name" role="tabpanel" aria-labelledby="tab-name" hidden>
            <label class="sr-only" for="name-search">Search cocktail names</label>
            <input
              type="text"
              class="ingredient-search"
              placeholder="Search cocktail names…"
              id="name-search"
              name="name-search"
              autocomplete="off"
              spellcheck="false"
            />
          </div>
        </div>

        <div class="filter-status" id="filter-status" role="status" aria-live="polite">
          <span class="result-count" id="result-count"></span>
          <button type="button" class="clear-btn" id="clear-filters" hidden>Clear Filters</button>
        </div>
      </div>

      <div class="empty" id="empty-state" role="status" aria-live="polite" hidden>
        <p>No cocktails match those filters.</p>
        <button type="button" class="clear-btn" id="clear-filters-empty">Clear Filters</button>
      </div>

      {categoryOrder.map((category) => (
        <section class="category-section" data-category-section={category}>
          <div class="section-header">
            <h2 class="section-title">{category}</h2>
            <span class="count" data-section-count>{grouped.get(category)!.length} recipe{grouped.get(category)!.length !== 1 ? 's' : ''}</span>
          </div>
          <div class="grid">
            {grouped.get(category)!.map((cocktail) => (
              <a
                href={`/${cocktail.slug}/`}
                data-glass={cocktail.glass}
                data-ingredients={[...new Set(cocktail.ingredients)].join('|')}
              >
                <div>
                  <img
                    src={`/images/responsive/320/${cocktail.slug}.webp`}
                    alt={cocktail.name}
                    width="320"
                    height="320"
                    loading={eagerSlugs.has(cocktail.slug) ? 'eager' : 'lazy'}
                    decoding={eagerSlugs.has(cocktail.slug) ? 'sync' : 'async'}
                    fetchpriority={eagerSlugs.has(cocktail.slug) ? 'high' : undefined}
                  />
                </div>
                <span>{cocktail.category}</span>
                <h3>{cocktail.name}</h3>
                <p>{cocktail.glass} &middot; {cocktail.ingredients.length} ingredients</p>
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>
  </div>
</Base>

<script is:inline>
(function() {
  const filters = { category: new Map(), glass: new Map(), ingredient: new Map() };
  let activeTab = 'category';
  let showAll = false;

  const $ = (s, p) => (p || document).querySelector(s);
  const $$ = (s, p) => (p || document).querySelectorAll(s);

  const cards = [...$$('.grid > a')];
  const cardData = cards.map((card) => ({
    el: card,
    category: card.closest('.category-section')?.dataset.categorySection || '',
    glass: card.dataset.glass,
    ingredients: card.dataset.ingredients ? card.dataset.ingredients.split('|') : [],
    name: $('h3', card)?.textContent?.toLowerCase() || '',
  }));
  const sections = [...$$('.category-section')];
  const tabs = [...$$('.filter-tab')];
  const panels = [...$$('[data-panel]')];
  const pills = [...$$('.pill')];
  const pillButtons = [...$$('.pill-action')];
  const countEl = $('#result-count');
  const emptyEl = $('#empty-state');
  const clearFiltersEl = $('#clear-filters');
  const searchEl = $('#ingredient-search');
  const showMoreEl = $('#show-more-ingredients');
  const ingredientPills = [...$$('[data-filter="ingredient"]')];
  const nameSearchEl = $('#name-search');
  const gridEl = $('#cocktail-grid');
  const tabKeys = tabs.map((tab) => tab.dataset.tab);
  const url = new URL(window.location.href);
  const slugMaps = {
    category: new Map(),
    glass: new Map(),
    ingredient: new Map(),
  };
  let visibleCount = cardData.length;
  let nameQuery = '';
  let isHydrating = true;

  function track(name, props) {
    if (typeof window.plausible === 'function') window.plausible(name, { props: props });
  }

  function toHashSlug(value) {
    return value
      .toLowerCase()
      .normalize('NFKD')
      .replace(/[\u0300-\u036f]/g, '')
      .replace(/&/g, ' and ')
      .replace(/[^a-z0-9]+/g, '-')
      .replace(/^-+|-+$/g, '')
      .replace(/-{2,}/g, '-');
  }

  function findPill(kind, value) {
    return pills.find((pill) => pill.dataset.filter === kind && pill.dataset.value === value);
  }

  function getIncluded(map) {
    return [...map].filter(([, state]) => state === 'include').map(([value]) => value);
  }

  function getExcluded(map) {
    return [...map].filter(([, state]) => state === 'exclude').map(([value]) => value);
  }

  function getPillSlug(kind, value) {
    const pill = findPill(kind, value);
    return pill?.dataset.slug || toHashSlug(value);
  }

  function normalizeFilters(source) {
    return {
      category: {
        include: getIncluded(source.category),
        exclude: getExcluded(source.category),
      },
      glass: {
        include: getIncluded(source.glass),
        exclude: getExcluded(source.glass),
      },
      ingredient: {
        include: getIncluded(source.ingredient),
        exclude: getExcluded(source.ingredient),
      },
    };
  }

  function matchesFilters(card, normalizedFilters) {
    let show = true;

    if (nameQuery && !card.name.includes(nameQuery)) show = false;
    if (normalizedFilters.category.include.length && !normalizedFilters.category.include.includes(card.category)) show = false;
    if (normalizedFilters.category.exclude.includes(card.category)) show = false;
    if (normalizedFilters.glass.include.length && !normalizedFilters.glass.include.includes(card.glass)) show = false;
    if (normalizedFilters.glass.exclude.includes(card.glass)) show = false;

    if (normalizedFilters.ingredient.include.length) {
      for (const ingredient of normalizedFilters.ingredient.include) {
        if (!card.ingredients.includes(ingredient)) {
          show = false;
          break;
        }
      }
    }

    if (show && normalizedFilters.ingredient.exclude.length) {
      for (const ingredient of normalizedFilters.ingredient.exclude) {
        if (card.ingredients.includes(ingredient)) {
          show = false;
          break;
        }
      }
    }

    return show;
  }

  function cloneFiltersWithOverride(kind, value, state) {
    const nextFilters = {
      category: new Map(filters.category),
      glass: new Map(filters.glass),
      ingredient: new Map(filters.ingredient),
    };

    if (state === null) nextFilters[kind].delete(value);
    else nextFilters[kind].set(value, state);

    return nextFilters;
  }

  function countVisibleWithOverride(kind, value, state) {
    const nextFilters = normalizeFilters(cloneFiltersWithOverride(kind, value, state));
    let nextVisibleCount = 0;

    for (const card of cardData) {
      if (matchesFilters(card, nextFilters)) nextVisibleCount++;
    }

    return nextVisibleCount;
  }

  function getDefaultTab() {
    if (nameQuery) return 'name';
    if (filters.ingredient.size > 0) return 'ingredients';
    if (filters.glass.size > 0) return 'glass';
    if (filters.category.size > 0) return 'category';
    return 'category';
  }

  function buildHashSegments(kind) {
    const included = getIncluded(filters[kind]).map((value) => getPillSlug(kind, value));
    const excluded = kind === 'category'
      ? []
      : getExcluded(filters[kind]).map((value) => `!${getPillSlug(kind, value)}`);
    const values = [...included, ...excluded];
    return values.length ? [kind, values.join(',')] : [];
  }

  function buildPrettyHash() {
    const segments = [
      ...buildHashSegments('category'),
      ...buildHashSegments('glass'),
      ...buildHashSegments('ingredient'),
    ];

    const searchValue = nameSearchEl.value.trim();
    if (searchValue) segments.push('search', toHashSlug(searchValue));

    const defaultTab = getDefaultTab();
    if (segments.length > 0 && activeTab !== defaultTab) segments.push('tab', activeTab);

    return segments.length ? `#${segments.join('/')}` : '';
  }

  function saveFilterCookie() {
    var hash = buildPrettyHash();
    if (hash) {
      document.cookie = 'filters=' + encodeURIComponent(hash) + ';path=/;SameSite=Lax';
    } else {
      document.cookie = 'filters=;path=/;max-age=0;SameSite=Lax';
    }
  }

  function getFilterCookie() {
    var match = document.cookie.match(/(?:^|; )filters=([^;]*)/);
    return match ? decodeURIComponent(match[1]) : null;
  }

  function syncUrl() {
    if (isHydrating) return;

    const nextUrl = `${window.location.pathname}${buildPrettyHash()}`;
    window.history.replaceState({}, '', nextUrl);
    saveFilterCookie();
  }

  function updatePill(el, state) {
    el.classList.remove('pill--include', 'pill--exclude');

    if (state === 'include') {
      el.classList.add('pill--include');
    } else if (state === 'exclude') {
      el.classList.add('pill--exclude');
    }

    const value = el.dataset.value;
    const kind = el.dataset.filter === 'ingredient' ? 'ingredient' : el.dataset.filter;
    const kindLabel = kind === 'glass' ? 'glass type' : kind;
    el.setAttribute('data-state', state || 'none');

    const includeButton = $('.pill-action--include', el);
    const excludeButton = $('.pill-action--exclude', el);

    if (includeButton) {
      includeButton.setAttribute('aria-pressed', String(state === 'include'));
      includeButton.setAttribute(
        'aria-label',
        state === 'include'
          ? `Clear included ${value} ${kindLabel}`
          : `Include ${value} ${kindLabel}`
      );
    }

    if (excludeButton) {
      excludeButton.setAttribute('aria-pressed', String(state === 'exclude'));
      excludeButton.setAttribute(
        'aria-label',
        state === 'exclude'
          ? `Clear excluded ${value} ${kindLabel}`
          : `Exclude ${value} ${kindLabel}`
      );
    }
  }

  function setActiveTab(nextTab, options) {
    const { focus = false, updateHistory = true } = options || {};
    activeTab = tabKeys.includes(nextTab) ? nextTab : 'category';

    for (const tab of tabs) {
      const isActive = tab.dataset.tab === activeTab;
      tab.classList.toggle('filter-tab--active', isActive);
      tab.setAttribute('aria-selected', String(isActive));
      tab.tabIndex = isActive ? 0 : -1;
    }

    for (const panel of panels) {
      panel.hidden = panel.dataset.panel !== activeTab;
    }

    if (focus && activeTab === 'name') nameSearchEl.focus();
    if (updateHistory) syncUrl();
  }

  function applyFilters(options) {
    const { updateHistory = true } = options || {};
    const normalizedFilters = normalizeFilters(filters);
    const hasFilters = filters.category.size + filters.glass.size + filters.ingredient.size > 0 || !!nameQuery;

    const sectionCounts = new Map();
    const glassCounts = new Map();
    const ingredientCounts = new Map();
    visibleCount = 0;

    for (const card of cardData) {
      const show = matchesFilters(card, normalizedFilters);
      card.el.hidden = !show;

      if (show) {
        visibleCount++;
        sectionCounts.set(card.category, (sectionCounts.get(card.category) || 0) + 1);
        glassCounts.set(card.glass, (glassCounts.get(card.glass) || 0) + 1);

        for (const ingredient of card.ingredients) {
          ingredientCounts.set(ingredient, (ingredientCounts.get(ingredient) || 0) + 1);
        }
      }
    }

    for (const section of sections) {
      const cat = section.dataset.categorySection;
      const count = sectionCounts.get(cat) || 0;
      section.hidden = count === 0;
      const countSpan = $('[data-section-count]', section);
      if (countSpan) countSpan.textContent = count + ' recipe' + (count !== 1 ? 's' : '');
    }

    updatePillVisibility();

    countEl.textContent = visibleCount + ' cocktail' + (visibleCount !== 1 ? 's' : '') + ' found';
    gridEl.classList.toggle('grid--filtered', hasFilters);
    clearFiltersEl.hidden = !hasFilters;
    emptyEl.hidden = visibleCount > 0 || !hasFilters;

    for (const tab of tabs) {
      const kind = tab.dataset.tab === 'ingredients' ? 'ingredient' : tab.dataset.tab;
      const badge = tab.querySelector('.filter-badge');
      const activeCount = kind === 'name' ? (nameQuery ? 1 : 0) : filters[kind]?.size || 0;

      if (activeCount > 0 && !badge) {
        tab.insertAdjacentHTML('beforeend', '<span class="filter-badge">' + activeCount + '</span>');
      } else if (activeCount > 0 && badge) {
        badge.textContent = activeCount;
      } else if (badge) {
        badge.remove();
      }
    }

    if (updateHistory) syncUrl();
  }

  function setPillActionVisibility(pill, includeVisible, excludeVisible) {
    const includeButton = $('.pill-action--include', pill);
    const excludeButton = $('.pill-action--exclude', pill);

    if (includeButton) includeButton.hidden = !includeVisible;
    if (excludeButton) excludeButton.hidden = !excludeVisible;

    pill.classList.toggle('pill--include-only', includeVisible && !excludeVisible);
    pill.classList.toggle('pill--exclude-only', !includeVisible && excludeVisible);
    pill.classList.toggle('pill--label-only', !includeVisible && !excludeVisible);
    pill.dataset.filterAvailable = String(includeVisible || excludeVisible);
  }

  function updatePillAvailability(pill) {
    const kind = pill.dataset.filter;
    const value = pill.dataset.value;
    const currentState = filters[kind].get(value) || null;
    const nextIncludeCount = countVisibleWithOverride(kind, value, 'include');
    const includeVisible =
      currentState === 'include' || (nextIncludeCount !== visibleCount && nextIncludeCount > 0);
    const nextExcludeCount = kind === 'category' ? visibleCount : countVisibleWithOverride(kind, value, 'exclude');
    const excludeVisible = kind === 'category'
      ? false
      :
      currentState === 'exclude' || (nextExcludeCount !== visibleCount && nextExcludeCount > 0);

    setPillActionVisibility(pill, includeVisible, excludeVisible);
    return currentState !== null || includeVisible || excludeVisible;
  }

  function updatePillVisibility() {
    for (const pill of pills) {
      const kind = pill.dataset.filter;
      if (kind === 'ingredient') continue;

      const shouldShow = updatePillAvailability(pill);
      pill.hidden = !shouldShow;
    }

    filterIngredientPills(searchEl.value);
  }

  function filterIngredientPills(query) {
    const normalizedQuery = query.trim().toLowerCase();
    let applicableInactiveCount = 0;
    let hiddenInactiveCount = 0;

    for (const pill of ingredientPills) {
      const value = pill.dataset.value;
      const name = value.toLowerCase();
      const isActive = filters.ingredient.has(value);
      const shouldShow = updatePillAvailability(pill);

      if (!shouldShow) {
        pill.hidden = true;
        continue;
      }

      if (normalizedQuery) {
        pill.hidden = !isActive && !name.includes(normalizedQuery);
        continue;
      }

      if (isActive) {
        pill.hidden = false;
      } else {
        pill.hidden = !showAll && applicableInactiveCount >= 20;
        if (pill.hidden) hiddenInactiveCount++;
        applicableInactiveCount++;
      }
    }

    const totalVisibleIngredients = ingredientPills.filter((pill) => pill.dataset.filterAvailable === 'true').length;
    showMoreEl.hidden = !!normalizedQuery || hiddenInactiveCount === 0;
    showMoreEl.setAttribute('aria-expanded', String(showAll));
    showMoreEl.textContent = showAll ? 'Show fewer' : 'Show all ' + totalVisibleIngredients + ' ingredients';
  }

  function setFilterValue(kind, value, state) {
    if (!value) return;
    if (state === null) filters[kind].delete(value);
    else filters[kind].set(value, state);

    const pill = findPill(kind, value);
    if (pill) updatePill(pill, state);
  }

  function getParamValues(name) {
    return [...new Set(url.searchParams.getAll(name).map((value) => value.trim()).filter(Boolean))];
  }

  function parseHashState() {
    if (!window.location.hash.startsWith('#')) return null;

    const normalizedHash = window.location.hash.slice(1).replace(/^\/+/, '');
    if (!normalizedHash) return null;

    const parts = normalizedHash.split('/').map((part) => part.trim()).filter(Boolean);
    if (parts.length < 2) return null;

    const parsed = {
      category: { include: [], exclude: [] },
      glass: { include: [], exclude: [] },
      ingredient: { include: [], exclude: [] },
      search: '',
      tab: '',
    };

    for (let i = 0; i < parts.length; i += 2) {
      const key = parts[i];
      const rawValue = parts[i + 1];
      if (!rawValue) continue;

      if (key === 'search') {
        parsed.search = rawValue.replace(/-/g, ' ');
        continue;
      }

      if (key === 'tab') {
        parsed.tab = rawValue;
        continue;
      }

      if (!slugMaps[key]) continue;

      for (const entry of rawValue.split(',').filter(Boolean)) {
        const isExclude = entry.startsWith('!');
        const slug = isExclude ? entry.slice(1) : entry;
        const value = slugMaps[key].get(slug);
        if (!value) continue;
        if (isExclude) parsed[key].exclude.push(value);
        else parsed[key].include.push(value);
      }
    }

    return parsed;
  }

  function hydrateFromUrl() {
    for (const pill of pills) updatePill(pill, null);

    // Restore from cookie if no hash or query params
    if (!window.location.hash && !url.search) {
      var saved = getFilterCookie();
      if (saved && saved.startsWith('#')) {
        window.location.hash = saved;
      }
    }

    const hashState = parseHashState();

    if (hashState) {
      for (const value of hashState.category.include) setFilterValue('category', value, 'include');
      for (const value of hashState.glass.include) setFilterValue('glass', value, 'include');
      for (const value of hashState.glass.exclude) setFilterValue('glass', value, 'exclude');
      for (const value of hashState.ingredient.include) setFilterValue('ingredient', value, 'include');
      for (const value of hashState.ingredient.exclude) setFilterValue('ingredient', value, 'exclude');
      nameQuery = hashState.search.trim().toLowerCase();
      nameSearchEl.value = hashState.search;
    } else {
      for (const value of getParamValues('category')) setFilterValue('category', value, 'include');
      for (const value of getParamValues('glass')) setFilterValue('glass', value, 'include');
      for (const value of getParamValues('excludeGlass')) setFilterValue('glass', value, 'exclude');
      for (const value of getParamValues('ingredient')) setFilterValue('ingredient', value, 'include');
      for (const value of getParamValues('excludeIngredient')) setFilterValue('ingredient', value, 'exclude');
      const searchValue = url.searchParams.get('q') || '';
      nameQuery = searchValue.trim().toLowerCase();
      nameSearchEl.value = searchValue;
    }

    const requestedTab = hashState?.tab || url.searchParams.get('tab');
    const nextTab =
      requestedTab ||
      getDefaultTab();

    setActiveTab(nextTab, { updateHistory: false });
    filterIngredientPills(searchEl.value);
    applyFilters({ updateHistory: false });
    isHydrating = false;
    if (hashState || url.search) syncUrl();
    if (window.location.hash && gridEl) gridEl.scrollIntoView({ block: 'start' });
  }

  // Handle broken images
  for (const card of cards) {
    const img = $('img', card);
    if (img) img.onerror = function() { this.parentElement.classList.add('empty'); };
  }

  for (const pill of pills) {
    if (!slugMaps[pill.dataset.filter].has(pill.dataset.slug)) {
      slugMaps[pill.dataset.filter].set(pill.dataset.slug, pill.dataset.value);
    }
  }

  var filterPanel = $('#filter-panel');

  for (const tab of tabs) {
    tab.addEventListener('click', function() {
      var isMobile = window.matchMedia('(max-width: 560px)').matches;
      if (isMobile && this.dataset.tab === activeTab && filterPanel.classList.contains('filter-panel--open')) {
        filterPanel.classList.remove('filter-panel--open');
        return;
      }
      filterPanel.classList.add('filter-panel--open');
      setActiveTab(this.dataset.tab, { focus: true });
      track('Filter Tab Selected', { tab: activeTab });
    });
    tab.addEventListener('keydown', function(event) {
      const currentIndex = tabKeys.indexOf(this.dataset.tab);
      if (currentIndex === -1) return;

      let nextIndex = null;
      if (event.key === 'ArrowRight') nextIndex = (currentIndex + 1) % tabKeys.length;
      if (event.key === 'ArrowLeft') nextIndex = (currentIndex - 1 + tabKeys.length) % tabKeys.length;
      if (event.key === 'Home') nextIndex = 0;
      if (event.key === 'End') nextIndex = tabKeys.length - 1;
      if (nextIndex === null) return;

      event.preventDefault();
      const nextTab = tabs[nextIndex];
      nextTab.focus();
      setActiveTab(nextTab.dataset.tab);
    });
  }

  for (const pillButton of pillButtons) {
    pillButton.addEventListener('click', function() {
      const pill = this.closest('.pill');
      if (!pill) return;

      const kind = pill.dataset.filter;
      const value = pill.dataset.value;
      const filterMap = filters[kind];
      const prev = filterMap.get(value) || null;
      const requestedState = this.dataset.action;
      const next = prev === requestedState ? null : requestedState;

      if (next === null) filterMap.delete(value);
      else filterMap.set(value, next);

      updatePill(pill, next);
      applyFilters();
      track('Filter Updated', {
        filter_type: kind,
        filter_value: value,
        action: next || 'cleared',
        previous_action: prev || 'none',
      });
    });
  }

  function clearAll() {
    track('Filters Cleared', {});
    for (const kind of ['category', 'glass', 'ingredient']) filters[kind].clear();
    for (const pill of pills) updatePill(pill, null);
    setActiveTab('category', { updateHistory: false });
    nameQuery = '';
    nameSearchEl.value = '';
    searchEl.value = '';
    showAll = false;
    showMoreEl.textContent = 'Show all ' + ingredientPills.length + ' ingredients';
    filterIngredientPills('');
    applyFilters();
  }

  $('#clear-filters').addEventListener('click', clearAll);
  $('#clear-filters-empty').addEventListener('click', clearAll);

  // Name search
  nameSearchEl.addEventListener('input', function() {
    nameQuery = this.value.toLowerCase().trim();
    applyFilters();
    if (nameQuery) track('Name Search', { query: nameQuery });
  });

  // Ingredient search
  searchEl.addEventListener('input', function() {
    filterIngredientPills(this.value);
  });

  showMoreEl.addEventListener('click', function() {
    showAll = !showAll;
    this.textContent = showAll ? 'Show fewer' : 'Show all ' + ingredientPills.length + ' ingredients';
    filterIngredientPills(searchEl.value);
  });

  hydrateFromUrl();
})();
</script>

