---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = 'Discover 500 cocktail recipes with ingredients, preparation methods, and more.', ogImage } = Astro.props;
const fullTitle = title === 'Cocktail Glass' ? title : `${title} | Cocktail Glass`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const ogImageUrl = ogImage ? new URL(ogImage, Astro.site).href : undefined;
const plausibleDomain = Astro.site ? new URL(Astro.site).hostname : undefined;
const shouldLoadPlausible = import.meta.env.PROD && plausibleDomain;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <title>{fullTitle}</title>
  <link rel="canonical" href={canonicalUrl} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
  {ogImageUrl && <meta property="og:image:width" content="1200" />}
  {ogImageUrl && <meta property="og:image:height" content="630" />}
  <meta name="twitter:card" content={ogImageUrl ? 'summary_large_image' : 'summary'} />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  {ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&family=Playfair+Display:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet" />
  {shouldLoadPlausible && (
    <>
      <script is:inline>
        window.plausible = window.plausible || function () {
          (window.plausible.q = window.plausible.q || []).push(arguments);
        };
      </script>
      <script defer data-domain={plausibleDomain} data-api="/api/event" src="/api/s"></script>
    </>
  )}
</head>
<body>
  <header class="site-header" id="site-header">
    <div class="container">
      <a href="/" class="logo">
        <span class="logo-icon">&#127864;</span>
        cocktail<span class="logo-dot">.glass</span>
      </a>
    </div>
  </header>
  <main>
    <slot />
  </main>
  <script>
    const hero = document.querySelector('.hero');
    const header = document.getElementById('site-header');
    if (hero && header) {
      const observer = new IntersectionObserver(
        ([entry]) => {
          header.classList.toggle('site-header--visible', !entry.isIntersecting);
        },
        { threshold: 0 }
      );
      observer.observe(hero);
    } else if (header) {
      header.classList.add('site-header--visible');
    }
  </script>
  <footer class="site-footer">
    <div class="container">
      <a href="/" class="footer-brand">cocktail<span>.glass</span></a>
      <p class="footer-tagline">Browse 500 cocktail recipes by category, glass, and ingredient</p>
    </div>
  </footer>
</body>
</html>

<style>
  .site-header {
    position: sticky;
    top: 0.75rem;
    z-index: 100;
    padding: 0 0.75rem;
    transform: translateY(-100%);
    opacity: 0;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  .site-header--visible {
    transform: translateY(0);
    opacity: 1;
  }

  .site-header .container {
    position: relative;
    display: flex;
    align-items: center;
    min-height: 4rem;
    padding-top: 0.8rem;
    padding-bottom: 0.8rem;
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.34), rgba(255, 255, 255, 0.14)),
      rgba(254, 249, 240, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.46);
    border-radius: 24px;
    box-shadow:
      0 18px 38px rgba(164, 125, 95, 0.1),
      inset 0 1px 0 rgba(255, 255, 255, 0.48);
    backdrop-filter: blur(22px) saturate(180%);
    -webkit-backdrop-filter: blur(22px) saturate(180%);
    overflow: hidden;
  }

  .site-header .container::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.3), rgba(255, 255, 255, 0)),
      radial-gradient(circle at left top, rgba(252, 182, 159, 0.12), transparent 40%),
      radial-gradient(circle at right top, rgba(166, 193, 238, 0.14), transparent 42%);
    pointer-events: none;
  }

  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .logo {
    position: relative;
    z-index: 1;
    font-family: var(--font-display);
    font-size: 1.75rem;
    color: var(--color-text);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-weight: 600;
  }

  .logo:hover {
    color: var(--color-text);
  }

  .logo-icon {
    font-size: 1.5rem;
  }

  .logo-dot {
    color: var(--color-accent);
  }

  .site-footer {
    padding: 3rem 0;
    margin-top: 4rem;
    text-align: center;
    color: var(--color-text-muted);
  }

  .footer-brand {
    font-family: var(--font-display);
    font-size: clamp(1.9rem, 4vw, 2.5rem);
    font-weight: 600;
    line-height: 0.98;
    letter-spacing: -0.02em;
    color: var(--color-text);
    display: inline-block;
  }

  .footer-brand span {
    color: var(--color-accent);
  }

  .footer-brand:hover {
    color: var(--color-text);
  }

  .footer-tagline {
    max-width: 32rem;
    margin: 0.75rem auto 0;
    font-size: 1.05rem;
    line-height: 1.6;
  }

  @media (max-width: 560px) {
    .site-header {
      top: 0.5rem;
      padding: 0 0.5rem;
    }

    .site-header .container {
      border-radius: 20px;
      min-height: 3.5rem;
      padding-top: 0.65rem;
      padding-bottom: 0.65rem;
    }

    .logo {
      font-size: 1.55rem;
      gap: 0.3rem;
    }

    .logo-icon {
      font-size: 1.25rem;
    }

    .site-footer {
      padding: 2.5rem 0;
    }

    .footer-brand {
      font-size: 2rem;
    }

    .footer-tagline {
      margin-top: 0.6rem;
      font-size: 0.98rem;
      max-width: 18rem;
    }
  }
</style>
