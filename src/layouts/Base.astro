---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  schema?: Record<string, unknown>;
}

const {
  title,
  description = 'Discover 500 cocktail recipes with ingredients, preparation methods, and more.',
  ogImage,
  schema,
} = Astro.props;
const fullTitle = title === 'Cocktail Glass' ? title : `${title} ~ Cocktail Glass`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const ogImageUrl = ogImage ? new URL(ogImage, Astro.site).href : undefined;
const plausibleDomain = Astro.site ? new URL(Astro.site).hostname : undefined;
const shouldLoadPlausible = import.meta.env.PROD && plausibleDomain;
const schemaJson = schema ? JSON.stringify(schema).replace(/</g, '\\u003c') : undefined;
const hasHeaderMeta = Astro.slots.has('headerMeta');
const hasHeaderActions = Astro.slots.has('headerActions');
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <title>{fullTitle}</title>
  <link rel="canonical" href={canonicalUrl} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
  {ogImageUrl && <meta property="og:image:width" content="1200" />}
  {ogImageUrl && <meta property="og:image:height" content="630" />}
  <meta name="twitter:card" content={ogImageUrl ? 'summary_large_image' : 'summary'} />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  {ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  {schemaJson && <script type="application/ld+json" set:html={schemaJson} />}
  <link rel="preload" href="/fonts/dm-sans-latin.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/playfair-display-latin.woff2" as="font" type="font/woff2" crossorigin />
  {shouldLoadPlausible && (
    <>
      <script is:inline>
        window.plausible = window.plausible || function () {
          (window.plausible.q = window.plausible.q || []).push(arguments);
        };
      </script>
      <script defer data-domain={plausibleDomain} data-api="/api/event" src="/api/s"></script>
    </>
  )}
</head>
<body>
  <div id="search-overlay" class="search-overlay">
    <div class="search-backdrop"></div>
    <div class="search-dialog">
      <div id="search-container"></div>
    </div>
  </div>
  <script is:inline>
    (function() {
      var overlay = document.getElementById('search-overlay');
      var loaded = false;

      function openSearch() {
        overlay.classList.add('search-overlay--open');
        document.body.style.overflow = 'hidden';
        if (!loaded) {
          loaded = true;
          var container = document.getElementById('search-container');
          container.innerHTML = '<input type="text" id="pf-input" class="pf-input" placeholder="Search cocktails..." autocomplete="off" /><div id="pf-results" class="pf-results"></div>';
          var pfInput = document.getElementById('pf-input');
          var pfResults = document.getElementById('pf-results');
          var pagefind;
          var debounce;

          import('/pagefind/pagefind.js').then(function(pf) {
            pagefind = pf;
            pagefind.options({
              ranking: {
                diacriticSimilarity: 0.0
              }
            });
            pagefind.init();
            pfInput.focus();
          });

          function titleScore(title, query) {
            var t = title.toLowerCase();
            var q = query.toLowerCase();
            if (t === q) return 0;
            if (t.startsWith(q + ' ') || t.startsWith(q + ':')) return 1;
            if (t.endsWith(' ' + q)) return 2;
            if (t.includes(q)) return 3;
            return 4;
          }

          pfInput.addEventListener('input', function() {
            clearTimeout(debounce);
            var q = pfInput.value;
            if (!q) { pfResults.innerHTML = ''; return; }
            debounce = setTimeout(async function() {
              var search = await pagefind.search(q);
              var results = await Promise.all(search.results.slice(0, 20).map(function(r) { return r.data(); }));
              results.sort(function(a, b) {
                return titleScore(a.meta.title || '', q) - titleScore(b.meta.title || '', q);
              });
              pfResults.innerHTML = results.slice(0, 15).map(function(r) {
                var slug = r.url.replace(/^\//, '').replace(/\/$/, '');
                var img = slug ? '<img src="/images/responsive/320/' + slug + '.webp" alt="" class="pf-result-image" width="48" height="48" loading="lazy" />' : '';
                return '<a href="' + r.url + '" class="pf-result">' +
                  img +
                  '<div class="pf-result-text">' +
                  '<span class="pf-result-title">' + (r.meta.title || 'Untitled') + '</span>' +
                  '<span class="pf-result-excerpt">' + (r.meta.excerpt || '') + '</span>' +
                  '</div></a>';
              }).join('') || '<p class="pf-empty">No results found.</p>';
            }, 200);
          });

          pfInput.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') { closeSearch(); }
          });
        } else {
          var pfInput = document.getElementById('pf-input');
          if (pfInput) { pfInput.focus(); pfInput.select(); }
        }
      }

      function closeSearch() {
        overlay.classList.remove('search-overlay--open');
        document.body.style.overflow = '';
      }

      document.addEventListener('keydown', function(e) {
        if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
          e.preventDefault();
          if (!overlay.classList.contains('search-overlay--open')) openSearch();
          else closeSearch();
        }
        if (e.key === 'Escape' && overlay.classList.contains('search-overlay--open')) {
          closeSearch();
        }
      });

      overlay.querySelector('.search-backdrop').addEventListener('click', closeSearch);
    })();
  </script>
  <a href="#main-content" class="skip-link">Skip to content</a>
  <header class="site-header" id="site-header">
    <div class="container">
      <a href="/" class="logo">
        <img src="/emoji/cocktail-glass.svg" alt="" class="logo-icon" width="24" height="24" aria-hidden="true" />
        <span>cocktail<span class="logo-dot">.glass</span></span>
      </a>
      {hasHeaderMeta && (
        <div class="site-header-meta">
          <slot name="headerMeta" />
        </div>
      )}
      {hasHeaderActions && (
        <div class="site-header-actions">
          <slot name="headerActions" />
        </div>
      )}
    </div>
  </header>
  <main id="main-content">
    <slot />
  </main>
  <script is:inline>
    const hero = document.querySelector('.hero');
    const header = document.getElementById('site-header');
    if (hero && header) {
      const observer = new IntersectionObserver(
        ([entry]) => {
          header.classList.toggle('site-header--visible', !entry.isIntersecting);
        },
        { threshold: 0 }
      );
      observer.observe(hero);
    } else if (header) {
      header.classList.add('site-header--visible');
    }
  </script>
  <footer class="site-footer">
    <div class="container">
      <img src="/emoji/cocktail-glass.svg" alt="" class="footer-icon" width="40" height="40" aria-hidden="true" />
      <a href="/" class="footer-brand">cocktail<span>.glass</span></a>
      <p class="footer-tagline">Browse 500 cocktail recipes by category, glass, and ingredient</p>
    </div>
  </footer>
</body>
</html>

<style>
  .skip-link {
    position: absolute;
    left: 1rem;
    top: -3rem;
    z-index: 200;
    background: rgba(254, 249, 240, 0.98);
    color: var(--color-text);
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 999px;
    padding: 0.65rem 1rem;
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.08);
    transition: top 0.2s ease;
  }

  .skip-link:focus-visible {
    top: 1rem;
  }

  .site-header {
    position: sticky;
    top: 0.75rem;
    z-index: 100;
    padding: 0 0.75rem;
    transform: translateY(-100%);
    opacity: 0;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  .site-header--visible {
    transform: translateY(0);
    opacity: 1;
  }

  .site-header .container {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: 4rem;
    padding-top: 0.8rem;
    padding-bottom: 0.8rem;
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.34), rgba(255, 255, 255, 0.14)),
      rgba(254, 249, 240, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.46);
    border-radius: 24px;
    box-shadow:
      0 18px 38px rgba(164, 125, 95, 0.1),
      inset 0 1px 0 rgba(255, 255, 255, 0.48);
    backdrop-filter: blur(22px) saturate(180%);
    -webkit-backdrop-filter: blur(22px) saturate(180%);
    overflow: hidden;
  }

  .site-header .container::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.3), rgba(255, 255, 255, 0)),
      radial-gradient(circle at left top, rgba(252, 182, 159, 0.12), transparent 40%),
      radial-gradient(circle at right top, rgba(166, 193, 238, 0.14), transparent 42%);
    pointer-events: none;
  }

  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .logo {
    position: relative;
    z-index: 1;
    font-family: var(--font-display);
    font-size: 1.75rem;
    color: var(--color-text);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.58rem;
    font-weight: 600;
  }

  .logo:hover {
    color: var(--color-text);
  }

  .logo-icon {
    width: 1.5rem;
    height: 1.5rem;
    display: block;
    flex-shrink: 0;
  }

  .logo-dot {
    color: var(--color-accent);
  }

  .site-header-meta,
  .site-header-actions {
    position: relative;
    z-index: 1;
  }

  .site-header-meta {
    flex: 1 1 auto;
    min-width: 0;
    display: flex;
    justify-content: center;
  }

  .site-header-actions {
    display: flex;
    justify-content: flex-end;
  }

  :global(.header-summary) {
    display: inline-flex;
    align-items: center;
    min-width: 0;
    padding: 0.45rem 0.8rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.42);
    border: 1px solid rgba(255, 255, 255, 0.36);
    color: var(--color-text-muted);
    font-size: 0.92rem;
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  :global(.header-actions-group) {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    flex-wrap: nowrap;
    justify-content: flex-end;
  }

  :global(.header-actions-group > *) {
    flex: 0 0 auto;
  }

  :global(.header-action) {
    display: inline-flex;
    align-items: center;
    min-height: 2.3rem;
    padding: 0.4rem 0.82rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.58);
    border: 1px solid rgba(0, 0, 0, 0.05);
    color: var(--color-text);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease;
    white-space: nowrap;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.04);
  }

  :global(.header-action:hover) {
    background: rgba(255, 255, 255, 0.78);
    color: var(--color-accent);
    border-color: rgba(224, 94, 58, 0.16);
  }

  .site-footer {
    padding: 3rem 0;
    margin-top: 4rem;
    text-align: center;
    color: var(--color-text-muted);
  }

  .footer-icon {
    width: 2.5rem;
    height: 2.5rem;
    display: block;
    margin: 0 auto 0.8rem;
  }

  .footer-brand {
    font-family: var(--font-display);
    font-size: clamp(1.9rem, 4vw, 2.5rem);
    font-weight: 600;
    line-height: 0.98;
    letter-spacing: -0.02em;
    color: var(--color-text);
    display: inline-block;
  }

  .footer-brand span {
    color: var(--color-accent);
  }

  .footer-brand:hover {
    color: var(--color-text);
  }

  .footer-tagline {
    max-width: 32rem;
    margin: 0.75rem auto 0;
    font-size: 1.05rem;
    line-height: 1.6;
  }

  @media (max-width: 560px) {
    .site-header {
      top: 0.5rem;
      padding: 0 0.5rem;
    }

    .site-header .container {
      border-radius: 20px;
      min-height: 3.5rem;
      padding-top: 0.65rem;
      padding-bottom: 0.65rem;
      gap: 0.65rem;
    }

    .logo {
      font-size: 1.55rem;
      gap: 0.42rem;
    }

    .logo-icon {
      width: 1.25rem;
      height: 1.25rem;
    }

    .site-header-meta,
    .site-header-actions {
      display: none;
    }

    .site-footer {
      padding: 2.5rem 0;
    }

    .footer-icon {
      width: 2.2rem;
      height: 2.2rem;
      margin-bottom: 0.65rem;
    }

    .footer-brand {
      font-size: 2rem;
    }

    .footer-tagline {
      margin-top: 0.6rem;
      font-size: 0.98rem;
      max-width: 18rem;
    }
  }

  .search-overlay {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: none;
    align-items: flex-start;
    justify-content: center;
    padding-top: 10vh;
  }

  .search-overlay.search-overlay--open {
    display: flex;
  }

  .search-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }

  .search-dialog {
    position: relative;
    width: 90%;
    max-width: 640px;
    max-height: 70vh;
    overflow-y: auto;
    background: rgba(254, 249, 240, 0.98);
    border-radius: 20px;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15);
    border: 1px solid rgba(0, 0, 0, 0.08);
  }
</style>

<style is:global>
  .pf-input {
    display: block;
    width: 100%;
    padding: 1rem 1.25rem;
    font-family: var(--font-sans);
    font-size: 1.1rem;
    font-weight: 500;
    border: none;
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
    background: transparent;
    color: var(--color-text);
    outline: none;
    border-radius: 20px 20px 0 0;
    -webkit-appearance: none;
    box-shadow: none;
  }

  .pf-input:focus {
    outline: none;
    box-shadow: none;
    border-bottom-color: var(--color-accent);
  }

  .pf-input::placeholder {
    color: var(--color-text-muted);
  }

  .pf-results {
    max-height: 55vh;
    overflow-y: auto;
    padding: 0.5rem 0;
  }

  .pf-result {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1.25rem;
    text-decoration: none;
    color: var(--color-text);
    transition: background 0.15s;
  }

  .pf-result:hover {
    background: rgba(224, 94, 58, 0.06);
  }

  .pf-result-image {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    object-fit: cover;
    border-radius: 10px;
  }

  .pf-result-text {
    flex: 1;
    min-width: 0;
  }

  .pf-result-title {
    display: block;
    font-weight: 600;
    font-size: 1rem;
    margin-bottom: 0.2rem;
  }

  .pf-result:hover .pf-result-title {
    color: var(--color-accent);
  }

  .pf-result-excerpt {
    display: block;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    line-height: 1.4;
  }

  .pf-result-excerpt mark {
    background: rgba(224, 94, 58, 0.15);
    color: var(--color-text);
    padding: 0.05em 0.15em;
    border-radius: 3px;
  }

  .pf-empty {
    padding: 1.5rem 1.25rem;
    color: var(--color-text-muted);
    text-align: center;
  }
</style>
