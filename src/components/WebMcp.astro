---
/**
 * WebMCP integration.
 *
 * Exposes the cocktail catalogue to in-browser AI agents via the
 * `navigator.modelContext` API (WebMCP — shipped as an early preview in
 * Chrome 146, Feb 2026, behind a flag; no other browsers yet). The script
 * feature-detects the API and does nothing where it is absent, so it is a
 * pure progressive enhancement.
 *
 * The six tool definitions and all matching logic are imported from
 * ../../cocktail-tools.mjs — the exact same module the remote MCP server
 * (functions/mcp.js) runs. This component is only the navigator.modelContext
 * transport adapter: it loads the catalogue, then wraps each shared `run` as
 * an async tool and registers it.
 *
 * This script is deliberately NOT `is:inline` (unlike most scripts on the
 * site): an inline script cannot `import`, and sharing one tool module with
 * the server is worth the trade. Astro bundles it once into a hashed,
 * cacheable module — so across 500 pages it is also fewer bytes than an
 * inline copy repeated in every HTML document.
 *
 * All tools are read-only. Cocktail data is fetched lazily from
 * /cocktails.json the first time any tool runs. Each in-browser tool call is
 * reported to /api/webmcp-usage so it shows up on /admin/stats alongside
 * remote MCP server usage.
 */
---

<script>
  import { TOOLS } from '../../cocktail-tools.mjs';

  const ctx = navigator.modelContext;

  if (ctx && typeof ctx.registerTool === 'function') {
    // Lazy, memoised fetch of the full catalogue. Records in /cocktails.json
    // already carry their `url`, which is exactly what the shared tools want.
    let catalogue;
    const loadCocktails = () => {
      if (!catalogue) {
        catalogue = fetch('/cocktails.json').then((res) => {
          if (!res.ok) throw new Error('Could not load cocktail data');
          return res.json();
        });
      }
      return catalogue;
    };

    const reply = (data) => ({
      content: [{ type: 'text', text: JSON.stringify(data) }],
    });

    // Report each in-browser tool call to the usage beacon (fire-and-forget)
    // so it appears on /admin/stats with surface = 'webmcp'.
    const reportUsage = (name, input) => {
      try {
        const payload = JSON.stringify({ tool: name, args: input || {} });
        if (navigator.sendBeacon) {
          navigator.sendBeacon('/api/webmcp-usage', payload);
        } else {
          fetch('/api/webmcp-usage', { method: 'POST', body: payload, keepalive: true });
        }
      } catch {
        /* never let logging break a tool call */
      }
    };

    // Wrap each shared tool: the remote server runs `run` synchronously over an
    // imported catalogue; in the browser the catalogue is fetched, so `run` is
    // awaited behind a lazy load. The matching logic itself is identical.
    for (const { name, description, inputSchema, annotations, run } of TOOLS) {
      try {
        ctx.registerTool({
          name,
          description,
          inputSchema,
          annotations,
          execute: async (input) => {
            reportUsage(name, input);
            const cocktails = await loadCocktails();
            return reply(run(cocktails, input || {}));
          },
        });
      } catch (err) {
        console.warn('[WebMCP] registerTool failed for', name, err);
      }
    }
  }
</script>
