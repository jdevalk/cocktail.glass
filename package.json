{
  "name": "cocktail-glass",
  "type": "module",
  "version": "0.0.1",
  "license": "MIT",
  "scripts": {
    "predev": "node scripts/generate-responsive-images.mjs",
    "dev": "astro dev",
    "prebuild": "node scripts/generate-responsive-images.mjs && node scripts/generate-og-images.mjs && node scripts/generate-agent-skills.mjs",
    "generate:skills": "node scripts/generate-agent-skills.mjs",
    "build": "astro build",
    "build:og": "node scripts/generate-og-images.mjs",
    "preview": "astro preview",
    "preview:pages": "npm run build && wrangler pages dev dist",
    "deploy:pages": "npm run build && wrangler pages deploy dist",
    "generate:origins": "node scripts/generate-origin-stories.mjs",
    "images": "node scripts/image-manager.mjs & sleep 1 && open http://localhost:3457"
  },
  "dependencies": {
    "@jdevalk/astro-seo-graph": "^1.1.1",
    "astro": "^6.1.1",
    "astro-pagefind": "^1.8.6",
    "gray-matter": "^4.0.3",
    "satori": "^0.26.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "wrangler": "^4.97.0"
  }
}
